# Copier ce fichier vers .env puis renseigner les clés (Stripe, etc.).
# Voir https://symfony.com/doc/current/configuration.html

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

# Dev (Vite) : http://localhost:5173 — Production Render (SPA sous /spa/) : https://TON-SERVICE.onrender.com/spa
FRONTEND_URL=http://localhost:5173

###> stripe ###
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_MODE=payment
###< stripe ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://symfony:PASSWORD@db:3306/symfony?serverVersion=10.8&charset=utf8mb4"
###< doctrine/doctrine-bundle ###
